{
  "manifest_version": 3,
  "name": "YYR Tab",
  "version": "1.0",
  "description": "Custom new tab page — tab dashboard",
  "permissions": ["tabs", "storage", "bookmarks", "windows"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "focus-or-open-newtab": {
      "suggested_key": {
        "mac": "Command+B",
        "windows": "Ctrl+B",
        "linux": "Ctrl+B",
        "chromeos": "Ctrl+B"
      },
      "description": "Focus existing New Tab or open a new one"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
